# PyroVeil Project - Git Ignore Configuration
# This file specifies intentionally untracked files that Git should ignore

# ============================================================================
# Build Artifacts
# ============================================================================

# CMake build directories
build/
build-*/
cmake-build-*/

# CMake cache and generated files
CMakeCache.txt
CMakeFiles/
CTestTestfile.cmake
cmake_install.cmake
install_manifest.txt
*.cmake.in

# Ninja build files
.ninja_deps
.ninja_log
rules.ninja
build.ninja

# Make build files
Makefile

# Compiled libraries and executables
*.so
*.so.*
*.a
*.o
*.obj
*.dll
*.dylib
*.exe

# Layer artifacts
libVkLayer_pyroveil*.so
VkLayer_pyroveil*.json

# ============================================================================
# IDE and Editor Files
# ============================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# CLion / IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Qt Creator
*.user
*.autosave
CMakeLists.txt.user*

# Vim
*.swp
*.swo
*~
.*.sw?

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

